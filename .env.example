# Supabase frontend configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional observability
VITE_SENTRY_DSN=
VITE_APP_ENV=local

# Optional security baseline script (do not expose service key in the browser)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Optional Playwright E2E credentials for staging/local validation
E2E_ADMIN_IDENTIFIER=
E2E_ADMIN_PASSWORD=
E2E_EMPLOYEE_IDENTIFIER=
E2E_EMPLOYEE_PASSWORD=
E2E_AUDIT_IDENTIFIER=
E2E_AUDIT_PASSWORD=
